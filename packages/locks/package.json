{
	"name": "@slipher/locks",
	"version": "0.0.1",
	"private": false,
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"lib/**"
	],
	"main": "./lib/index.js",
	"module": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./redis": {
			"types": "./lib/redis.d.ts",
			"default": "./lib/redis.js"
		}
	},
	"typesVersions": {
		"*": {
			"redis": [
				"./lib/redis.d.ts"
			]
		}
	},
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"lint": "biome lint ./src ./test",
		"format": "biome format --write ./src ./test",
		"checkb": "biome check --no-errors-on-unmatched ./src ./test",
		"test": "pnpm build && vitest run --config ./test/vitest.config.mts ./test/",
		"prepublish": "pnpm build"
	},
	"peerDependencies": {
		"@redis/client": "^5.10.0"
	},
	"peerDependenciesMeta": {
		"@redis/client": {
			"optional": true
		}
	},
	"devDependencies": {
		"@redis/client": "^5.10.0",
		"@types/node": "^25.0.10",
		"typescript": "^5.9.3"
	}
}
