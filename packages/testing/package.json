{
	"name": "@slipher/testing",
	"version": "0.0.1",
	"private": false,
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"lib/**"
	],
	"main": "./lib/index.js",
	"module": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"scripts": {
		"dev": "tsc --watch",
		"build": "pnpm --filter @slipher/internal build && tsc && node ../../scripts/vendor-internal.mjs testing",
		"lint": "biome lint --write ./src ./test",
		"format": "biome format --write ./src ./test",
		"checkb": "biome check --write --no-errors-on-unmatched ./src ./test",
		"typecheck": "pnpm --filter @slipher/internal build && tsc --noEmit --project ./test/tsconfig.json",
		"test": "pnpm typecheck && vitest run --config ./test/vitest.config.mts ./test/",
		"prepublishOnly": "pnpm build"
	},
	"devDependencies": {
		"@slipher/internal": "workspace:*",
		"@slipher/types": "workspace:*",
		"@biomejs/biome": "2.3.11",
		"@types/node": "^25.0.10",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
