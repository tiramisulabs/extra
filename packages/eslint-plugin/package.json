{
	"name": "@slipher/eslint-plugin",
	"version": "0.1.0",
	"private": false,
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"lib/**"
	],
	"main": "./lib/index.js",
	"module": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"scripts": {
		"dev": "tsc --watch",
		"build": "tsc",
		"lint": "biome lint --write ./src",
		"format": "biome format --write ./src",
		"checkb": "biome check --write --no-errors-on-unmatched ./src",
		"test": "vitest run --config ./test/vitest.config.mts ./test/",
		"prepublish": "pnpm build"
	},
	"peerDependencies": {
		"eslint": ">=9.0.0",
		"seyfert": ">=5.0.0",
		"typescript": ">=5.0.0"
	},
	"dependencies": {
		"@typescript-eslint/utils": "^8.62.0"
	},
	"devDependencies": {
		"@types/node": "^26.0.1",
		"@typescript-eslint/rule-tester": "^8.62.0",
		"eslint": "^10.6.0",
		"seyfert": "^5.0.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vitest": "^4.1.9"
	}
}
