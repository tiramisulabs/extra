{
	"compilerOptions": {
		"module": "CommonJS",
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"types": ["node"],
		"declaration": true,
		"strict": true,
		"esModuleInterop": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"noErrorTruncation": true,
		"rootDir": "./src",
		"outDir": "./lib",
		"stripInternal": true
	},
	"exclude": ["**/lib", "**/test", "**/examples"]
}
